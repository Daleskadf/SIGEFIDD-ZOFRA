        private int GetBadgeCount()
        {
            string conn = ConfigurationManager.ConnectionStrings["FirmaDigital"].ConnectionString;
            using (var cn = new SqlConnection(conn))
            {
                cn.Open();
                using (var cmd = new SqlCommand(
                    "SELECT COUNT(*) FROM Documento d JOIN Maestro m ON d.IdEstadoDocumento=m.IdMaestro WHERE d.Activo=1 AND m.Codigo IN ('REG','REV','PEN','FPAR','OBS')", cn))
                    return Convert.ToInt32(cmd.ExecuteScalar());
            }
        }

        private void CargarCategorias()
        {
            string conn = ConfigurationManager.ConnectionStrings["FirmaDigital"].ConnectionString;
            using (var cn = new SqlConnection(conn))
            {
                cn.Open();
                using (var cmd = new SqlCommand("SELECT IdMaestro, Descripcion FROM Maestro WHERE Tipo='TIPO_DOC' AND Activo=1 ORDER BY Orden", cn))
                using (var dr = cmd.ExecuteReader())
                {
                    ddlCategoria.Items.Clear();
                    ddlCategoria.Items.Add(new ListItem("Seleccionar...", ""));
                    while (dr.Read())
                        ddlCategoria.Items.Add(new ListItem(dr["Descripcion"].ToString(), dr["IdMaestro"].ToString()));
                }
            }
        }

        private void CargarUsuariosParaFirmar()
        {
            string conn = ConfigurationManager.ConnectionStrings["FirmaDigital"].ConnectionString;
            using (var cn = new SqlConnection(conn))
            {
                cn.Open();
                string sql = @"SELECT u.LoginUsuario, m.Descripcion AS RolNombre
                               FROM UsuarioSistema u
                               JOIN Maestro m ON u.IdRolSistema = m.IdMaestro
                               WHERE u.Activo=1 AND m.Codigo IN ('FIR','REV')
                               ORDER BY m.Orden, u.LoginUsuario";
                using (var cmd = new SqlCommand(sql, cn))
                using (var dr = cmd.ExecuteReader())
                {
                    ddlFirmante.Items.Clear();
                    ddlFirmante.Items.Add(new ListItem("Seleccionar usuario...", ""));
                    while (dr.Read())
                        ddlFirmante.Items.Add(new ListItem(
                            dr["LoginUsuario"] + " (" + dr["RolNombre"] + ")",
                            dr["LoginUsuario"].ToString()
                        ));
                }
            }
        }

        private void BindFirmantes()
        {
            rptFirmantes.DataSource = Firmantes;
            rptFirmantes.DataBind();
        }

        protected void btnAgregarFirmante_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(ddlFirmante.SelectedValue))
            { MostrarMsg("Seleccione un usuario para agregar.", false); return; }

            string loginSel = ddlFirmante.SelectedValue;

            if (Firmantes.Exists(f => f.Login == loginSel))
            { MostrarMsg("Ese usuario ya está en la lista.", false); return; }

            string textoItem = ddlFirmante.SelectedItem.Text;
            string tipo = textoItem.Contains("Firmante") ? "Firmante" : "Revisor";

            Firmantes.Add(new FirmanteItem
            {
                Orden = Firmantes.Count + 1,
                Login = loginSel,
                Tipo = tipo
            });

            BindFirmantes();
            MostrarMsg("Usuario agregado correctamente.", true);
        }

        protected void rptFirmantes_ItemCommand(object source, RepeaterCommandEventArgs e)
        {
            if (e.CommandName == "Eliminar")
            {
                Firmantes.RemoveAll(f => f.Login == e.CommandArgument.ToString());
                for (int i = 0; i < Firmantes.Count; i++)
                    Firmantes[i].Orden = i + 1;
                BindFirmantes();
            }
        }

        protected void btnCargar_Click(object sender, EventArgs e)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(txtTitulo.Text) || string.IsNullOrWhiteSpace(ddlCategoria.SelectedValue))
                { MostrarMsg("Complete los campos obligatorios.", false); return; }
                if (!filePDF.HasFile || filePDF.PostedFile == null)
                { MostrarMsg("Debe adjuntar un archivo PDF.", false); return; }
                if (Path.GetExtension(filePDF.FileName).ToLower() != ".pdf")
                { MostrarMsg("Solo se permiten archivos PDF.", false); return; }
                if (filePDF.PostedFile.ContentLength > 10 * 1024 * 1024)
                { MostrarMsg("El archivo supera los 10MB.", false); return; }
                if (Firmantes.Count == 0)
                { MostrarMsg("Debe agregar al menos un firmante.", false); return; }

                // Leer PDF en memoria
                byte[] pdfBytes;
                using (BinaryReader br = new BinaryReader(filePDF.PostedFile.InputStream))
                    pdfBytes = br.ReadBytes(filePDF.PostedFile.ContentLength);

                if (pdfBytes.Length == 0) { MostrarMsg("El PDF está vacío.", false); return; }

                string nombreArchivo = DateTime.Now.ToString("yyyyMMddHHmmss") + "_" + Path.GetFileName(filePDF.FileName);
                int horasRev = int.TryParse(txtPlazoRevision.Text.Trim(), out int hr) ? hr : 24;
                int horasFirma = int.TryParse(txtPlazoFirma.Text.Trim(), out int hf) ? hf : 48;

                string connDoc = ConfigurationManager.ConnectionStrings["FirmaDigital"].ConnectionString;
                string connFile = ConfigurationManager.ConnectionStrings["FirmaDigital_Files"].ConnectionString;

                int idDocumento;

                // PASO 1: Guardar documento + participantes en FirmaDigital
                using (var cn = new SqlConnection(connDoc))
                {
                    cn.Open();

                    int idEstadoReg;
                    using (var cmd = new SqlCommand(
                        "SELECT IdMaestro FROM Maestro WHERE Tipo='ESTADO_DOC' AND Codigo='REG'", cn))
                    {
                        object r = cmd.ExecuteScalar();
                        if (r == null || r == DBNull.Value)
                        { MostrarMsg("ERROR: No existe estado REG en Maestro.", false); return; }
                        idEstadoReg = Convert.ToInt32(r);
                    }

                    string codigo = "DOC-" + DateTime.Now.ToString("yyyyMMddHHmmss");
                    string sql = @"INSERT INTO Documento
                        (CodigoDocumento,Asunto,Descripcion,IdTipoDocumento,
                         AreaResponsable,AreaCategoria,LoginUsuarioRegistrador,
                         IdEstadoDocumento,Prioridad,FechaLimiteRevision,FechaLimiteAprobacion)
                        VALUES
                        (@cod,@asunto,@desc,@tipo,@area,@catdesc,@login,@estado,@pri,@limRev,@limFirma);
                        SELECT SCOPE_IDENTITY();";

                    using (var cmd = new SqlCommand(sql, cn))
                    {
                        cmd.Parameters.AddWithValue("@cod", codigo);
                        cmd.Parameters.AddWithValue("@asunto", txtTitulo.Text.Trim());
                        cmd.Parameters.AddWithValue("@desc", txtDescripcion.Text.Trim());
                        cmd.Parameters.AddWithValue("@tipo", int.Parse(ddlCategoria.SelectedValue));
                        cmd.Parameters.AddWithValue("@area", txtDescripcion.Text.Trim().Length > 0 ? txtDescripcion.Text.Trim() : txtTitulo.Text.Trim());
                        cmd.Parameters.AddWithValue("@catdesc", ddlCategoria.SelectedItem.Text);
                        cmd.Parameters.AddWithValue("@login", Session["LoginUsuario"].ToString());
                        cmd.Parameters.AddWithValue("@estado", idEstadoReg);
                        cmd.Parameters.AddWithValue("@pri", ddlPrioridad.SelectedValue);
                        cmd.Parameters.AddWithValue("@limRev", DateTime.Now.AddHours(horasRev));
                        cmd.Parameters.AddWithValue("@limFirma", DateTime.Now.AddHours(horasFirma));

                        object scalar = cmd.ExecuteScalar();
                        if (scalar == null || scalar == DBNull.Value)
                        { MostrarMsg("No se pudo crear el documento.", false); return; }
                        idDocumento = Convert.ToInt32(scalar);
                    }

                    // Obtener IdMaestro de tipos y estado PEN una sola vez
                    int idTipoFirmante, idTipoRevisor, idEstadoPen;

                    using (var cmd = new SqlCommand(
                        "SELECT Codigo, IdMaestro FROM Maestro WHERE Tipo IN ('TIPO_PARTICIPANTE','ESTADO_PARTICIPANTE') AND Codigo IN ('FIR','REV','PEN')", cn))
                    using (var dr = cmd.ExecuteReader())
                    {
                        idTipoFirmante = 0; idTipoRevisor = 0; idEstadoPen = 0;
                        while (dr.Read())
                        {
                            string cod = dr["Codigo"].ToString();
                            int id = Convert.ToInt32(dr["IdMaestro"]);
                            if (cod == "FIR") idTipoFirmante = id;
                            else if (cod == "REV") idTipoRevisor = id;
                            else if (cod == "PEN") idEstadoPen = id;
                        }
                    }

                    // Insertar cada participante
                    foreach (var f in Firmantes)
                    {
                        int idTipo = f.Tipo == "Firmante" ? idTipoFirmante : idTipoRevisor;

                        string sqlPart = @"INSERT INTO DocumentoParticipante
                            (IdDocumento,LoginUsuario,OrdenSecuencial,IdTipoParticipante,EstadoParticipante)
                            VALUES (@idDoc,@login,@orden,@tipo,@estado)";

                        using (var cmd = new SqlCommand(sqlPart, cn))
                        {
                            cmd.Parameters.AddWithValue("@idDoc", idDocumento);
                            cmd.Parameters.AddWithValue("@login", f.Login);
                            cmd.Parameters.AddWithValue("@orden", f.Orden);
                            cmd.Parameters.AddWithValue("@tipo", idTipo);
                            cmd.Parameters.AddWithValue("@estado", idEstadoPen);
                            cmd.ExecuteNonQuery();
                        }
                    }
                }

                // PASO 2: Guardar PDF en FirmaDigital_Files
                using (var cn = new SqlConnection(connFile))
                {
                    cn.Open();
                    string sqlAdj = @"INSERT INTO DocumentoAdjunto
                        (IdDocumento,ContenidoPDF,NombreArchivo,TipoMime,TamanioBytes,UsuarioCreacion)
                        VALUES (@id,@pdf,@nom,@mime,@size,@user)";

                    using (var cmd = new SqlCommand(sqlAdj, cn))
                    {
                        cmd.CommandTimeout = 120;
                        cmd.Parameters.AddWithValue("@id", idDocumento);
                        cmd.Parameters.Add("@pdf", System.Data.SqlDbType.VarBinary, -1).Value = pdfBytes;
                        cmd.Parameters.AddWithValue("@nom", nombreArchivo);
                        cmd.Parameters.AddWithValue("@mime", "application/pdf");
                        cmd.Parameters.AddWithValue("@size", pdfBytes.Length);
                        cmd.Parameters.AddWithValue("@user", Session["LoginUsuario"].ToString());
                        cmd.ExecuteNonQuery();
                    }
                }

                // Limpiar todo
                Session["FirmantesTemp"] = new List<FirmanteItem>();
                BindFirmantes();
                txtTitulo.Text = ""; txtDescripcion.Text = "";
                txtPlazoRevision.Text = "24"; txtPlazoFirma.Text = "48";
                MostrarMsg("✔ Documento registrado y firmantes asignados correctamente.", true);
            }
            catch (Exception ex)
            {
                MostrarMsg("ERROR: " + ex.Message + " | " + (ex.InnerException?.Message ?? ""), false);
            }
        }

